# UtilsFlow Environment Variables
# Copy this file to .env and fill in values

# Site URL (used for sitemap & OG tags)
VITE_SITE_URL=https://utilsflow.web.app

# Google Analytics (optional)
VITE_GA_ID=

# AdSense Publisher ID (optional - for monetization)
VITE_ADSENSE_ID=

# HaveIBeenPwned API Key (optional - for password breach check)
VITE_HIBP_API_KEY=
